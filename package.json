{
  "name": "ultrabuild",
  "version": "0.1.0",
  "description": "The cross-platform agentic harness for every model, every agent, and every tool.",
  "type": "module",
  "bin": {
    "ultrabuild": "dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/",
    "docs/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "test": "npm run build && node scripts/run-tests.mjs",
    "e2e": "npm run build && node scripts/e2e.mjs",
    "package:all": "node scripts/package-release.mjs",
    "smoke:release": "node scripts/smoke-release.mjs",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agentic",
    "coding-agent",
    "cli",
    "ai",
    "harness",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VoidChecksum/UltraBuild.git"
  },
  "homepage": "https://github.com/VoidChecksum/UltraBuild#readme",
  "bugs": {
    "url": "https://github.com/VoidChecksum/UltraBuild/issues"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  }
}
